# Rust
/target/
**/*.rs.bk

# debt-scan generated reports
/reports/

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Per-vendor AI tool personal areas (synced from .skillshare/ via the
# skillshare tool — not committed). The vendor-neutral source of truth
# for committed skills lives under .skillshare/skills/.
.claude/
.cursor/
.codex/
.gemini/
.agents/

# Per-developer state that should not be shared. Personal verifiers
# and orchestrators live in the maintainer's own dotfiles (see
# ADR-0004); anything they write back into the repo lands here and
# stays local.
.skillshare/records/
.skillshare/agents/
.skillshare/logs/
.skillshare/maintainer-notes/

# Per-developer local overrides for AGENTS-style memory files.
# CLAUDE.md (committed) imports AGENTS.md; CLAUDE.local.md is appended
# on top for personal notes that should not be shared.
CLAUDE.local.md
AGENTS.local.md

# lefthook local override (per-developer)
lefthook-local.yml

# gitleaks per-developer personal rules
.gitleaks-local.toml

# Secrets / credentials. gitleaks catches accidental leaks at commit time,
# but ignoring these patterns is the first line of defence.
.env
.env.*
!.env.example
*.secret
*.secrets
secrets/
